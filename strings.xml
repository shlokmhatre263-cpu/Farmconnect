    <string name="pm_kisan">PM Kisan Samman Nidhi</string>
    <string name="pm_kisan_desc">₹6000 per year financial support to farmers.</string>
    <string name="eligibility_pm_kisan">• Must be Indian citizen\n• Small or marginal farmer\n• Own cultivable land</string>
    <string name="documents_pm_kisan">• Aadhaar Card\n• Bank Passbook\n• Land Records\n• Mobile Number</string>
    <string name="how_to_apply_pm_kisan">1. Visit pmkisan.gov.in\n2. Click New Farmer Registration\n3. Enter Aadhaar &amp; bank details\n4. Submit form online</string>

    <string name="pm_fasal_bima">PM Fasal Bima Yojana</string>
    <string name="pm_fasal_bima_desc">Crop insurance against natural disasters.</string>
    <string name="eligibility_pm_fasal">• Registered farmer\n• Crop must be notified under scheme\n• Must insure before crop season</string>
    <string name="documents_pm_fasal">• Aadhaar Card\n• Bank Account Details\n• Land Ownership Proof\n• Crop Details</string>
    <string name="how_to_apply_pm_fasal">1. Visit pmfby.gov.in\n2. Select your state\n3. Fill crop details\n4. Pay premium &amp; submit</string>

    <string name="pm_sinchai">PM Krishi Sinchai Yojana</string>
    <string name="pm_sinchai_desc">Support for irrigation systems and water management.</string>
    <string name="eligibility_sinchai">• Farmer with irrigation requirement\n• Own or leased agricultural land</string>
    <string name="documents_sinchai">• Land Records\n• Bank Details\n• Aadhaar Card</string>
    <string name="how_to_apply_sinchai">1. Visit pmksy.gov.in\n2. Select your scheme component\n3. Apply through district office\n4. Submit required documents</string>

    <string name="kisan_credit_card">Kisan Credit Card</string>
    <string name="kisan_credit_card_desc">Easy loan facility for farming needs.</string>
    <string name="eligibility_kcc">• Farmer with cultivable land\n• Individual or joint borrower</string>
    <string name="documents_kcc">• Aadhaar Card\n• Land Documents\n• Bank Account\n• Passport Photo</string>
    <string name="how_to_apply_kcc">1. Visit nearest bank branch\n2. Fill KCC application form\n3. Submit land &amp; ID documents\n4. Bank will process the card</string>

