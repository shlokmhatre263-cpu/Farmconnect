<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#EAF4EA"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Greeting -->
    <TextView
        android:id="@+id/tvGreeting"
        android:text="@string/welcome"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:layout_marginStart="24dp"
        android:layout_marginTop="40dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <!-- Grid Layout -->
    <GridLayout
        android:id="@+id/gridMenu"
        android:columnCount="2"
        android:layout_below="@id/tvGreeting"
        android:layout_above="@id/bottomNav"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- WEATHER CARD -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardWeather"
            android:layout_margin="14dp"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_columnWeight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="28dp"
            app:cardElevation="14dp">

            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:src="@drawable/ic_weather"
                    android:layout_width="48dp"
                    android:layout_height="48dp"/>

                <TextView
                    android:text="@string/weather"
                    android:textSize="18sp"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- DISEASE CARD -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardDisease"
            android:layout_margin="14dp"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_columnWeight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="28dp"
            app:cardElevation="14dp">

            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:src="@drawable/ic_disease"
                    android:layout_width="48dp"
                    android:layout_height="48dp"/>

                <TextView
                    android:text="@string/crop_disease"
                    android:textSize="18sp"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- COMMUNITY CARD -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCommunity"
            android:layout_margin="14dp"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_columnWeight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="28dp"
            app:cardElevation="14dp">

            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:src="@drawable/ic_community"
                    android:layout_width="48dp"
                    android:layout_height="48dp"/>

                <TextView
                    android:text="@string/community"
                    android:textSize="18sp"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SCHEMES CARD -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSchemes"
            android:layout_margin="14dp"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_columnWeight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="28dp"
            app:cardElevation="14dp">

            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:src="@drawable/ic_schemes"
                    android:layout_width="48dp"
                    android:layout_height="48dp"/>

                <TextView
                    android:text="@string/schemes"
                    android:textSize="18sp"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- MARKETPLACE CARD -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardMarketplace"
            android:layout_margin="14dp"
            android:layout_width="0dp"
            android:layout_height="160dp"
            android:layout_columnWeight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="28dp"
            app:cardElevation="14dp">

            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:text="🛒"
                    android:textSize="40sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="@string/marketplace"
                    android:textSize="18sp"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:layout_marginTop="14dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </GridLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_menu"/>

</RelativeLayout>