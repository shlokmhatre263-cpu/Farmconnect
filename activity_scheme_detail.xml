<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#F4FFF4"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView android:id="@+id/tvDetailTitle"
            android:textSize="22sp" android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:id="@+id/tvDetailDescription"
            android:textSize="15sp" android:layout_marginTop="12dp"
            android:textColor="#444444"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:text="@string/eligibility"
            android:textStyle="bold" android:textSize="18sp"
            android:textColor="#2E7D32" android:layout_marginTop="24dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:id="@+id/tvEligibility"
            android:textSize="14sp" android:layout_marginTop="6dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:text="@string/documents_required"
            android:textStyle="bold" android:textSize="18sp"
            android:textColor="#2E7D32" android:layout_marginTop="24dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:id="@+id/tvDocuments"
            android:textSize="14sp" android:layout_marginTop="6dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:text="@string/how_to_apply"
            android:textStyle="bold" android:textSize="18sp"
            android:textColor="#2E7D32" android:layout_marginTop="24dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:id="@+id/tvHowToApply"
            android:textSize="14sp" android:layout_marginTop="6dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <!-- ✅ REAL Apply Online Button -->
        <Button
            android:id="@+id/btnApplyOnline"
            android:text="@string/apply_online"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:padding="14dp"
            android:backgroundTint="#4CAF50"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</ScrollView>