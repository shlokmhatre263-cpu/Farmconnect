<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#EAF4EA"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:text="@string/marketplace_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:padding="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:background="#FFFFFF"
        app:tabSelectedTextColor="#2E7D32"
        app:tabIndicatorColor="#2E7D32"
        app:tabTextColor="#888888"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Spinner
        android:id="@+id/spinnerCropFilter"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/edit_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <FrameLayout android:layout_weight="1"
        android:layout_width="match_parent"
        android:layout_height="0dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerMarketplace"
            android:padding="8dp"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <ProgressBar android:id="@+id/progressMarket"
            android:visibility="gone"
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView android:id="@+id/tvMarketEmpty"
            android:text="@string/no_listings"
            android:gravity="center"
            android:textSize="15sp"
            android:textColor="#888888"
            android:visibility="gone"
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabSell"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="@string/sell_crop"
            android:layout_gravity="bottom|end"
            android:layout_margin="20dp"
            app:backgroundTint="#2E7D32"
            app:tint="#FFFFFF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </FrameLayout>

</LinearLayout>