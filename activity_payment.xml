<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#EAF4EA"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout android:orientation="vertical" android:padding="20dp"
        android:layout_width="match_parent" android:layout_height="wrap_content">

        <TextView android:text="@string/payment_title" android:textSize="22sp"
            android:textStyle="bold" android:textColor="#2E7D32"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <androidx.cardview.widget.CardView app:cardCornerRadius="16dp" app:cardElevation="6dp"
            android:layout_marginBottom="20dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical" android:padding="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="@string/order_summary" android:textSize="13sp"
                    android:textStyle="bold" android:textColor="#888888"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvOrderSummary" android:textSize="15sp"
                    android:textColor="#333333" android:layout_marginTop="4dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvOrderTotal" android:textSize="26sp"
                    android:textStyle="bold" android:textColor="#E65100"
                    android:layout_marginTop="6dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvPayMethodLabel" android:textSize="13sp"
                    android:textColor="#777777" android:layout_marginTop="4dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- UPI Panel -->
        <LinearLayout android:id="@+id/layoutUPI" android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:id="@+id/tvUpiId" android:textSize="16sp"
                android:textStyle="bold" android:textColor="#1B5E20"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <FrameLayout android:background="#DDDDDD"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="14dp"
                android:layout_width="150dp" android:layout_height="150dp">
                <TextView android:text="@string/qr_placeholder"
                    android:textColor="#777777" android:textSize="15sp"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </FrameLayout>
            <TextView android:text="@string/enter_upi_pin"
                android:textColor="#2E7D32" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etUpiPin" android:hint="@string/upi_pin_hint"
                android:inputType="numberPassword" android:background="@drawable/edit_bg"
                android:layout_marginTop="4dp" android:layout_marginBottom="14dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnPayUPI" android:text="@string/pay_upi"
                android:textColor="#FFFFFF" android:textStyle="bold" android:padding="14dp"
                android:background="@drawable/green_button"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Card Panel -->
        <LinearLayout android:id="@+id/layoutCard" android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:text="@string/card_number"
                android:textColor="#2E7D32" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etCardNumber" android:hint="1234 5678 9012 3456"
                android:inputType="number" android:maxLength="16"
                android:background="@drawable/edit_bg"
                android:layout_marginTop="4dp" android:layout_marginBottom="12dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <LinearLayout android:orientation="horizontal"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <LinearLayout android:orientation="vertical" android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="@string/card_expiry"
                        android:textColor="#2E7D32" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <EditText android:id="@+id/etCardExpiry" android:hint="MM/YY"
                        android:inputType="number" android:maxLength="4"
                        android:background="@drawable/edit_bg"
                        android:layout_marginTop="4dp" android:layout_marginBottom="12dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </LinearLayout>
                <LinearLayout android:orientation="vertical" android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_width="0dp" android:layout_height="wrap_content">
                    <TextView android:text="@string/card_cvv"
                        android:textColor="#2E7D32" android:textStyle="bold"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <EditText android:id="@+id/etCardCvv" android:hint="123"
                        android:inputType="numberPassword" android:maxLength="3"
                        android:background="@drawable/edit_bg"
                        android:layout_marginTop="4dp" android:layout_marginBottom="12dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
            <TextView android:text="@string/card_holder_name"
                android:textColor="#2E7D32" android:textStyle="bold"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <EditText android:id="@+id/etCardName" android:hint="@string/card_name_hint"
                android:inputType="textCapCharacters" android:background="@drawable/edit_bg"
                android:layout_marginTop="4dp" android:layout_marginBottom="14dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnPayCard" android:text="@string/pay_card"
                android:textColor="#FFFFFF" android:textStyle="bold" android:padding="14dp"
                android:background="@drawable/green_button"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- COD Panel -->
        <LinearLayout android:id="@+id/layoutCOD" android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:text="@string/cod_title" android:textSize="17sp"
                android:textStyle="bold" android:textColor="#1B5E20"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="@string/cod_info"
                android:textSize="14sp" android:textColor="#555555"
                android:lineSpacingExtra="4dp" android:layout_marginBottom="16dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnConfirmCOD" android:text="@string/confirm_cod"
                android:textColor="#FFFFFF" android:textStyle="bold" android:padding="14dp"
                android:background="@drawable/green_button"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Wallet Panel -->
        <LinearLayout android:id="@+id/layoutWallet" android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:text="@string/farmwallet_title" android:textSize="17sp"
                android:textStyle="bold" android:textColor="#1B5E20"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvWalletBalance" android:textSize="16sp"
                android:textColor="#2E7D32" android:textStyle="bold"
                android:layout_marginBottom="16dp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnPayWallet" android:text="@string/pay_wallet"
                android:textColor="#FFFFFF" android:textStyle="bold" android:padding="14dp"
                android:background="@drawable/green_button"
                android:layout_marginBottom="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>

        <ProgressBar android:id="@+id/progressPayment" android:visibility="gone"
            android:layout_gravity="center"
            android:layout_marginTop="24dp" android:layout_marginBottom="12dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <!-- Success Screen -->
        <LinearLayout android:id="@+id/layoutSuccess" android:orientation="vertical"
            android:gravity="center" android:visibility="gone"
            android:layout_marginTop="20dp" android:padding="16dp"
            android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:text="✅" android:textSize="60sp" android:gravity="center"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <TextView android:text="@string/order_placed" android:textSize="20sp"
                android:textStyle="bold" android:textColor="#2E7D32" android:gravity="center"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvSuccessOrderId" android:textSize="13sp"
                android:textColor="#555555" android:gravity="center"
                android:layout_marginTop="10dp" android:layout_marginBottom="20dp"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <Button android:id="@+id/btnGoOrders" android:text="@string/view_my_orders"
                android:textColor="#FFFFFF" android:textStyle="bold" android:padding="14dp"
                android:background="@drawable/green_button"
                android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>