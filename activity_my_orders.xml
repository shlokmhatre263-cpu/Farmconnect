<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#EAF4EA"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView android:text="@string/my_orders_title" android:textSize="22sp"
        android:textStyle="bold" android:textColor="#2E7D32" android:padding="16dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <FrameLayout android:layout_weight="1"
        android:layout_width="match_parent" android:layout_height="0dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerOrders" android:padding="8dp"
            android:clipToPadding="false"
            android:layout_width="match_parent" android:layout_height="match_parent"/>

        <ProgressBar android:id="@+id/progressOrders" android:visibility="gone"
            android:layout_gravity="center"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

        <TextView android:id="@+id/tvNoOrders"
            android:text="@string/no_orders_yet"
            android:textColor="#888888" android:textSize="15sp"
            android:gravity="center" android:visibility="gone"
            android:layout_gravity="center"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    </FrameLayout>
</LinearLayout>